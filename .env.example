# ==============================================================
# ChatTAX - Environment variables
# העתק את הקובץ הזה ל-.env.local לפיתוח מקומי.
# ב-Vercel: הוסף את כל המשתנים ב-Project Settings → Environment Variables.
# ==============================================================

# ---------- Google Gemini (AI) ----------
# קבל מפתח חינם ב-https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ---------- Firebase - Web SDK (Client-side, נחשף בדפדפן) ----------
# מ-Firebase Console → Project Settings → General → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:xxxxxxxxxxxxxx

# ---------- Firebase - Admin SDK (Server-only, סופר-רגיש) ----------
# בפיתוח מקומי: קובץ firebase-admin.json בשורש הפרויקט (מוגן ב-.gitignore).
# ב-Vercel: הכנס את כל התוכן של הקובץ כשורה אחת של JSON (ראה DEPLOYMENT.md).
# הפורמט: {"type":"service_account","project_id":"...","private_key":"...", ...}
FIREBASE_ADMIN_JSON=

# ---------- Lemon Squeezy (תשלומים) ----------
# Server-only: הסוד לאימות ה-webhook (Settings → Webhooks → Signing secret)
LEMONSQUEEZY_WEBHOOK_SECRET=
# Public: קישורי ה-Checkout של כל מוצר (כפתור Share ליד המוצר ב-Lemon Squeezy)
NEXT_PUBLIC_LS_CHECKOUT_PRO=
NEXT_PUBLIC_LS_CHECKOUT_ULTRA=
# אופציונלי: מזהי Variant מספריים. אם ריק — הזיהוי לפי שם המוצר (PRO/ULTRA).
LS_VARIANT_PRO=
LS_VARIANT_ULTRA=
